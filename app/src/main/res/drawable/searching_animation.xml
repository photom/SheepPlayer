<?xml version="1.0" encoding="utf-8"?>
<animation-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:oneshot="false">

    <!-- Frame 1: Sheep looking left -->
    <item android:duration="500">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#2C3E50"
                        android:endColor="#3498DB"
                        android:angle="45" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <item android:gravity="center">
                <group>
                    <!-- Sheep body (white oval) -->
                    <shape android:shape="oval">
                        <solid android:color="#FFFFFF" />
                        <size
                            android:width="80dp"
                            android:height="60dp" />
                    </shape>
                </group>
            </item>
        </layer-list>
    </item>

    <!-- Frame 2: Sheep looking right -->
    <item android:duration="500">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#2C3E50"
                        android:endColor="#3498DB"
                        android:angle="45" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <item android:gravity="center">
                <group>
                    <!-- Sheep body (white oval) -->
                    <shape android:shape="oval">
                        <solid android:color="#F8F9FA" />
                        <size
                            android:width="80dp"
                            android:height="60dp" />
                    </shape>
                </group>
            </item>
        </layer-list>
    </item>

    <!-- Frame 3: Sheep with magnifying glass -->
    <item android:duration="500">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#2C3E50"
                        android:endColor="#3498DB"
                        android:angle="45" />
                    <corners android:radius="8dp" />
                </shape>
            </item>
            <item android:gravity="center">
                <group>
                    <!-- Sheep body with search icon -->
                    <shape android:shape="oval">
                        <solid android:color="#FFFFFF" />
                        <stroke
                            android:width="2dp"
                            android:color="#3498DB" />
                        <size
                            android:width="80dp"
                            android:height="60dp" />
                    </shape>
                </group>
            </item>
        </layer-list>
    </item>

</animation-list>